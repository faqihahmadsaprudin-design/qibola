<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="15dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tvRank" android:layout_width="30dp" android:layout_height="wrap_content" android:textColor="#FFF" android:textStyle="bold"/>
    <ImageView android:id="@+id/imgLogo" android:layout_width="35dp" android:layout_height="35dp" android:layout_marginEnd="15dp"/>
    <TextView android:id="@+id/tvTeamName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#FFF"/>
    <TextView android:id="@+id/tvPlayed" android:layout_width="50dp" android:layout_height="wrap_content" android:textColor="#94A3B8" android:textSize="12sp"/>
    <TextView android:id="@+id/tvPoints" android:layout_width="60dp" android:layout_height="wrap_content" android:textColor="#3B82F6" android:textStyle="bold" android:textAlignment="viewEnd"/>
</LinearLayout>